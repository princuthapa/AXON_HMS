       <property name="styleSheet">
        <string notr="true">/* Optimized 3-Bars Menu Button */
QPushButton#logoutBtn {
    background-color: transparent;
    color: #475569;             /* Slate text color */
    border: none;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 20px;            /* Bumps up the size of the bars */
    font-weight: bold;          /* Makes the bars look clean and solid */
    padding: 0px 6px;
    margin-bottom: 2px;         /* Keeps it perfectly vertically aligned with the text */
}

QPushButton#logoutBtn:hover {
    color: #0f172a;
    background-color: #e2e8f0;  /* Soft grey hover box */
    border-radius: 6px;
}

QPushButton::menu-indicator{
	image:none;
	width: 0 px;
	height:0 px;
}</string>
