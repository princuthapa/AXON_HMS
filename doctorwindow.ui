   <property name="styleSheet">
    <string notr="true">/* 1. Sidebar Frame Styling */
QFrame#sideBarFrame {
    background-color: #FDFBF7; 
    border-right: 1px solid #e2e8f0;
}

/* 2. Target your specific buttons by object name regardless of hierarchy */
#overviewBtn,#patientlistBtn, #scheduleBtn {
    background-color: transparent;
    border: none;
    text-align: left;
    padding-left: 15px;
    font-weight: normal;
}

/* 3. Hover State */
#overviewBtn:hover, #patientlistBtn:hover, #scheduleBtn:hover {
    background-color: #f1f5f9; 
    border-radius: 10px;
}

/* 4. Active / Checked State */
#overviewBtn:checked, 
#patientlistBtn:checked, 
#scheduleBtn:checked {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #ccffff, stop:1 #ffffff);
    border-radius: 10px;
    font-weight: bold;
}</string>
   </property>
