     <property name="styleSheet">
      <string notr="true">/* 1. Sidebar Frame Styling */
QFrame#sidebarFrame {
    background-color: #FDFBF7; 
    border-right: 1px solid #e2e8f0;
}

/* 2. Target your specific buttons by object name regardless of hierarchy */
#btnOverview, #btnStaffManager, #btnScheduling {
    background-color: transparent;
    border: none;
    text-align: left;
    padding-left: 15px;
    font-weight: normal;
}

/* 3. Hover State */
#btnOverview:hover, #btnStaffManager:hover, #btnScheduling:hover {
    background-color: #f1f5f9; 
    border-radius: 10px;
}

/* 4. Active / Checked State */
#btnOverview:checked, #btnStaffManager:checked, #btnScheduling:checked {
    background-color: qlineargradient(spread:pad, x1:0, y1:0, x2:1, y2:0, stop:0 #ccffff, stop:1 #ffffff);
    border-radius: 10px;
    font-weight: bold;
}</string>
