         <property name="styleSheet">
          <string notr="true">/* Style all four card containers */
QFrame {
    background-color: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
}

/* FORCE every single label inside the cards to be dark and visible by default */
QFrame QLabel {
    color: #475569 !important;
    font-family: &quot;Segoe UI&quot;, Arial;
}

/* Make the big number labels extra large and dark */
QLabel#lblValueStaff, 
QLabel#lblValuePatients, 
QLabel#lblValueReceptionists {
    color: #0f172a !important;
    font-size: 28px !important;
    font-weight: bold !important;
}

/* Make the revenue number pop in Teal/Green */
QLabel#lblValueRevenue {
    color: #0d9488 !important;
    font-size: 28px !important;
    font-weight: bold !important;
}</string>
