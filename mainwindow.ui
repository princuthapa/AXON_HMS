  <property name="styleSheet">
   <string notr="true">/* Sharp white background card container */
QWidget {
    background-color: #ffffff;
    border: 1px solid #dcdad4;
    border-radius: 16px;
}

/* Explicitly target only the input boxes and dropdowns for the pill shape */
QComboBox, QLineEdit {
    background-color: #fcfbfa;
    border: 1px solid #dcdad4;
    border-radius: 18px;
    color: #1a1a1a;
    padding: 8px 15px;
}

QLineEdit:focus, QComboBox:focus {
    border: 1px solid #1a1a1a;
}

/* Fix the Title Label: Strip away borders and background, make it bold and dark */
QLabel#authTitle {
    background: transparent;
    border: none;
    color: #1a1a1a;
    font-weight: bold;
    font-size: 14px;
}

/* Style for the solid black Login Button */
QPushButton {
    background-color: #1a1a1a;
    border: 1px solid #1a1a1a;
    border-radius: 18px;
    color: #ffffff;
    font-weight: bold;
    padding: 10px;
}

QPushButton:hover {
    background-color: #ffffff;
    color: #1a1a1a;
}</string>
