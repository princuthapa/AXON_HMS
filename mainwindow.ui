          <property name="styleSheet">
           <string notr="true">QPushButton {
    /* Soft, friendly light blue */
    background-color: #e3f2fd; 
    
    /* Deep navy text color for sharp, readable contrast */
    color: #0d47a1;            
    
    /* Clean 2px border matching the text */
    border: 2px solid #0d47a1; 
    
    /* Smooth capsule shape */
    border-radius: 15px;       
    
    font-size: 13px;
    font-weight: bold;
}

/* When the cursor floats over the button */
QPushButton:hover {
    /* Fills into a richer, slightly darker sky blue */
    background-color: #bbdefb; 
}

/* When the user physically clicks the button down */
QPushButton:pressed {
    /* Deepens temporarily on click for tactile feedback */
    background-color: #90caf9; 
}</string>
